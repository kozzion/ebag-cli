# Copy to `.env` and fill in your ebag.bg credentials.
# `.env` is git-ignored — never commit real credentials.
#
# Used by `ebag login`. Real environment variables override these.

EBAG_EMAIL=you@example.com
EBAG_PASSWORD=your-password

# Optional: where to store the session cookie jar (default: ~/.ebag/session.json)
# EBAG_SESSION_FILE=.ebag-session.json
